{
  "name": "xeq-gui",
  "version": "1.2.2",
  "description": "GUI wallet for Equilibria (XEQ)",
  "productName": "XEQ GUI",
  "repository": {
    "type": "git",
    "url": "https://github.com/EquilibriaHorizon/XEQ-GUI.git"
  },
  "cordovaId": "com.equilibria.xeq-wallet",
  "author": {
    "name": "Equilibria",
    "email": "contact@equilibria.cc"
  },
  "private": true,
  "scripts": {
    "dev": "quasar dev -m electron",
    "build": "quasar build -m electron --publish=never",
    "build:win": "quasar build -m electron --publish=never -T win",
    "build:linux": "quasar build -m electron --publish=never -T linux",
    "build:mac": "quasar build -m electron --publish=never -T mac",
    "build:all": "npm run build:win && npm run build:linux",
    "lint": "eslint --fix .",
    "format": "prettier --write \"**/*.+(js|jsx|json|yml|yaml|css|md|vue)\"",
    "ready": "npm run lint && npm run format"
  },
  "dependencies": {
    "@vuelidate/core": "^2.0.3",
    "@vuelidate/validators": "^2.0.4",
    "autoprefixer": "^10.4.24",
    "axios": "^1.7.9",
    "bunyan": "^1.8.15",
    "electron-updater": "^6.3.9",
    "electron-window-state": "^5.0.3",
    "fs-extra": "^11.2.0",
    "object-assign-deep": "^0.4.0",
    "portscanner": "^2.2.0",
    "promise-queue": "^2.2.5",
    "qrcode.vue": "^3.6.0",
    "quasar": "^2.17.7",
    "semver": "^7.6.3",
    "upath": "^2.0.1",
    "vue": "^3.5.0",
    "vue-i18n": "^11.1.2",
    "vue-timeago3": "^2.3.2",
    "vuex": "^4.1.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@quasar/app-vite": "^2.1.0",
    "@quasar/extras": "^1.16.15",
    "dotenv": "^16.4.7",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9.17.0",
    "eslint-plugin-vue": "^9.32.0",
    "prettier": "^3.4.2",
    "stylus": "^0.64.0",
    "vue-router": "^4.5.0"
  },
  "engines": {
    "node": ">= 20.0.0",
    "npm": ">= 10.0.0"
  },
  "browserslist": [
    "last 2 Chrome versions"
  ]
}
