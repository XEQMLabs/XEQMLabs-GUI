// XEQMLabs Dark Theme Variables
// --------------------------------------------------
// Space-themed dark palette with electric cyan accent

// Primary Colors
$primary   = #00d4ff  // Electric cyan - main accent
$secondary = #0a3d4d  // Muted cyan for secondary elements
$accent    = #00d4ff  // Same as primary for consistency

// Status Colors
$positive  = #00ff88  // Bright green for success
$negative  = #ff4757  // Red for errors/danger
$warning   = #ffaa00  // Orange/amber for warnings
$info      = #00d4ff  // Cyan for info

$neutral   = #1a2029  // Dark neutral

// Background Hierarchy (darkest to lightest)
$bg-void   = #000000  // Deepest black - main background
$bg-space  = #030508  // Space black - body background
$bg-panel  = #080c12  // Panel background
$bg-card   = #0c1218  // Card/elevated surfaces
$bg-hover  = #101820  // Hover state
$bg-input  = #0a0e14  // Input fields

// Border Colors
$border-subtle = rgba(0, 212, 255, 0.1)   // Subtle cyan border
$border-default = rgba(0, 212, 255, 0.2)  // Default border
$border-strong = rgba(0, 212, 255, 0.3)   // Strong border

// Text Colors (white with opacity)
$text-primary   = rgba(255, 255, 255, 0.92)  // Primary text
$text-secondary = rgba(255, 255, 255, 0.60)  // Secondary text
$text-muted     = rgba(200, 205, 210, 0.65)  // Muted/placeholder text - white-grey
$text-accent    = #00d4ff                     // Accent colored text

// Legacy variable mappings (for compatibility)
$oxen-navy = $bg-panel
$oxen-teal = $primary
$oxen-light-teal = $secondary
$oxen-purple = $bg-hover

$off-grey = $bg-hover

$loki-green = $positive
$loki-black-60 = $bg-panel
