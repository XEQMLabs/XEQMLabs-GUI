// XEQMLabs Dark Theme Styles
// --------------------------------------------------
@import 'quasar.variables'
@import 'flags'

// Self-hosted JetBrains Mono - no external requests, air-gap compatible
@font-face {
    font-family: 'JetBrains Mono';
    font-style: normal;
    font-weight: 400;
    font-display: swap;
    src: url('../assets/fonts/JetBrainsMono-Regular.ttf') format('truetype');
}
@font-face {
    font-family: 'JetBrains Mono';
    font-style: normal;
    font-weight: 500;
    font-display: swap;
    src: url('../assets/fonts/JetBrainsMono-Medium.ttf') format('truetype');
}
@font-face {
    font-family: 'JetBrains Mono';
    font-style: normal;
    font-weight: 600;
    font-display: swap;
    src: url('../assets/fonts/JetBrainsMono-SemiBold.ttf') format('truetype');
}

// Base font family - JetBrains Mono throughout (self-hosted only)
body, html {
    font-family: 'JetBrains Mono', monospace;
    background: $bg-void;
    color: $text-primary;
}

// Monospace utility class (same as base now)
.monospace, .mono {
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: -0.02em;
}

// Selection styling
::selection {
    background: rgba(0, 212, 255, 0.3);
    color: white;
}
::-moz-selection {
    background: rgba(0, 212, 255, 0.3);
    color: white;
}

// Scrollbar styling (dark theme)
* {
    scrollbar-track-color: $bg-void;
    scrollbar-arrow-color: $bg-void;
    &::-webkit-scrollbar-corner { background-color: $bg-void;}
    &::-webkit-scrollbar-track-piece { background-color: $bg-void;}

    scrollbar-face-color: $bg-panel;
    scrollbar-base-color: $bg-panel;
    scrollbar-3dlight-color: $bg-panel;
    scrollbar-highlight-color: $bg-panel;
    scrollbar-shadow-color: $bg-panel;
    scrollbar-dark-shadow-color: $bg-panel;
    &::-webkit-scrollbar { width: 8px; height: 8px;}
    &::-webkit-scrollbar-button { background-color: $bg-panel; height:0; width: 0; }
    &::-webkit-scrollbar-track { background-color: $bg-void;}
    &::-webkit-scrollbar-thumb {
        height: 50px;
        background-color: rgba(0, 212, 255, 0.2);
        border-radius: 4px;
        &:hover {
            background-color: rgba(0, 212, 255, 0.3);
        }
    }
    &::-webkit-resizer { background-color: $bg-panel;}
}

// Non-selectable elements
h1,h2,h3,h4,h5,h6,
img,
.q-list-header,
.q-header,
.q-menu .q-item-label,
.q-list-link .q-item,
.q-checkbox .q-option-label,
.infoBox .text,
.modal-header,
footer,
{
    -webkit-user-select: none !important;
    -moz-user-select: none !important;
    -ms-user-select: none !important;
    user-select: none !important;
}

// Utility classes
.break-all {
    word-break: break-all
}

.ellipsis {
    text-overflow: ellipsis;
    overflow: hidden;
}

.truncate-item {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

// Form styling
.q-field {
    margin: 20px 0;

    &.q-ma-none {
        margin: 0;
    }
}

.text-area-oxen {
  margin-top: 0px;
  margin-bottom: 0px;
}

// Disabled inputs/textareas: allow text-selection/copy, no not-allowed cursor.
input[disabled], textarea[disabled], input[readonly], textarea[readonly] {
  cursor: text !important;
}
.q-field--disabled, .q-field--readonly {
  cursor: text !important;
  .q-field__control, input, textarea { cursor: text !important; }
}

.q-inner-loading {
    z-index: 2;
}

.q-btn {
    text-transform: none;
}

.submit-button {
    margin-top: 6px;
}

.layout-padding {
    padding: 15px 16px !important;
}

.advanced-options-label .q-item-side-right {
    margin: 0;
    text-align: left;
}

// Main layout - dark backgrounds
.q-layout, .app-content {
    background: $bg-space;
    color: $text-primary;
}

// Header styling
.q-header {
    background: $bg-void;
    box-shadow: none;
    border-bottom: 1px solid $border-default;
    height: 48px;

    &.shift-title {
        .q-toolbar {
            text-align: center;

            .q-toolbar-title {
                font-size: 16px;
                line-height: 48px;
                font-weight: 500;
            }
        }
    }

    .q-btn.menu {
        height: 48px;
        width: 50px;
        position: absolute;
        top: 0;
        z-index: 1;
        border-radius: 0;
    }
    .q-btn.cancel {
        position: absolute;
        top: 7px;
        left: 8px;
        z-index: 1;
    }

    .q-toolbar-inverted {
        background: $bg-panel;
        padding-top: 0;
    }

    .q-tabs {
        padding-left: 50px;

        .q-tabs-head {
            padding: 0;
            background: none;
        }

        .q-tab {
            text-transform: none;
            color: $text-secondary;

            &:hover {
                color: $text-primary;
            }

            .q-icon {
                font-size: 22px;
            }
        }
    }
}

.q-layout-page {
    min-height: 0 !important;
}

// Info boxes
.infoBox {
    min-height: 75px;
    cursor: default;
    position: relative;
    overflow: hidden;
    margin: 10px 0;
    padding: 12px 16px;
    background: $bg-card;
    border: 1px solid $border-subtle;
    border-radius: 8px;

    .infoBoxIcon {
        position: absolute;
        right: 10px;
        top: 10px;
        width: 64px;
        color: $text-muted;

        svg {
            width: 60px;
            height: 60px;
        }
    }

    .infoBoxContent {
        display: inline-block;

        .text {
            font-size: 13px;
            color: $text-secondary;
        }

        .value {
            font-size: 20px;
            margin-top: 6px;
            font-weight: 500;
            color: $text-primary;
            font-family: 'JetBrains Mono', monospace;
            line-height: 1.2;
            word-break: break-all;
        }
    }
}

// Checkbox styling
.q-checkbox {
    color: $text-primary;

    .q-checkbox__inner {
        color: rgba(255, 255, 255, 0.5);
    }

    .q-checkbox__inner--falsy .q-checkbox__bg {
        border-color: rgba(255, 255, 255, 0.45);
    }

    .q-option-label {
        color: rgba(255, 255, 255, 0.8);
    }
}

// Global input field styling for dark theme
.q-field__label {
    color: rgba(255, 255, 255, 0.6) !important;
}

.q-field--focused .q-field__label {
    color: #00d4ff !important;
}

.q-field__native,
.q-field__input {
    color: rgba(255, 255, 255, 0.92) !important;
}

.q-field__control::before {
    border-color: rgba(255, 255, 255, 0.3) !important;
}

.q-field--focused .q-field__control::after {
    border-color: #00d4ff !important;
}

// Radio button styling for dark theme
.q-radio {
    color: rgba(255, 255, 255, 0.8);

    .q-radio__inner {
        color: rgba(255, 255, 255, 0.5);
    }

    .q-radio__inner--falsy .q-radio__bg {
        border-color: rgba(255, 255, 255, 0.45);
    }
}

// Loading overlay
.q-loading + .modal {
    z-index: 9999 !important;
}

.modal-scroll {
    max-height: 230px;
    max-width: 640px;
    word-break: break-word;
}

// Footer status bar
.q-footer.status-footer {
    background: $bg-void;
    color: $text-secondary;
    border-top: 1px solid $border-default;
    padding-top: 2px;
    box-shadow: none;
    font-size: 12px;

    .status-line {
        padding: 8px;
        margin-bottom: 5px;

        .status {
            flex: 1;
            span {
                margin-right: 4px;
            }

            .status-text {
                font-weight: 600;
            }

            .ready {
              color: $positive;
            }

            .scanning, .syncing {
                color: $warning;
            }

            .offline {
                color: #FFA726;  // Amber/orange for offline
            }

            .updateRequired {
                color: $negative;
            }
        }

        div {
            padding: 0 8px;
        }
    }

    .status-bars {
        div {
            height: 3px;
            position: absolute;
            bottom: 0;
            left: 0;
            transition: width 0.5s ease-out;
        }

        div:first-child {
            background-color: $positive;
        }

        div:last-child {
            background-color: $positive;
        }
    }

    .status-bars.syncing, .status-bars.scanning {
        div:first-child {
            background-color: $warning;
        }

        div:last-child {
            background-color: $warning;
        }
    }

    .status-bars.offline {
        div:first-child {
            background-color: #FFA726;
        }

        div:last-child {
            background-color: #FFA726;
        }
    }

    .status-bars.updateRequired {
        div:first-child {
            background-color: $negative;
        }

        div:last-child {
            background-color: $negative;
        }
    }
}

// Transaction list
.tx-list {
    .meta {
        text-align: right;
        font-family: 'JetBrains Mono', monospace;
    }

    .q-item.tx-in,
    .q-item.tx-pool,
    .q-item.tx-miner,
    .q-item.tx-snode,
    .q-item.tx-gov {
        .amount span {
            color: $positive;
            font-family: 'JetBrains Mono', monospace;
            &:before {
                content: "+";
                color: $positive;
            }
        }
    }

    .q-item.tx-stake {
        .amount span {
            color: $warning;
            font-family: 'JetBrains Mono', monospace;
        }
    }

    .q-item.tx-out,
    .q-item.tx-pending {
        .amount span {
            color: $text-primary;
            font-family: 'JetBrains Mono', monospace;
            &:before {
                content: "-";
                font-weight: bold;
            }
        }
    }

    .q-item.tx-failed {
        .amount span {
            color: $negative;
            font-family: 'JetBrains Mono', monospace;
        }
    }

    .q-item.tx-unlock_request {
        .amount span {
            color: #129fca;
            font-family: 'JetBrains Mono', monospace;
        }
    }

    .transaction .main {
        border-left: 1px solid $border-default;
    }
}

// List items dark theme
.q-list-dark .q-item,
.q-item-dark .q-item,
.q-list-header {
    color: $text-primary;
}

.q-stepper-tab.step-waiting,
.q-stepper-step-content{
    color: $text-secondary;
}

// Menu styling
.q-menu {
    background: $bg-card;
    color: $text-primary !important;
    border: 1px solid $border-default;
    border-radius: 8px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);

    * {
        color: $text-primary;
    }

    .q-list-separator > .q-item-division + .q-item-division, .q-item-division + .q-separator {
        border-top: 1px solid $border-subtle;
    }
}

.menu-list {
    background: $bg-card;

    .q-item * {
        color: $text-primary;
    }
}

.context-menu-list {
  min-width: 150px;
  max-height: 300px;
}

// Confirm transaction dialog
.confirm-tx-card {
  width: 450px;
  max-width: 450px;
  background: $bg-card;
  color: $text-primary !important;
  border: 1px solid $border-default;
  border-radius: 12px;

  .confirm-list {
    .q-item {
      max-height: 100%;
      margin-top: 0;
      margin-bottom: 4px;
      padding-top: 0;
      padding-bottom: 0;
    }
  }

  .label {
    color: $text-accent;
    padding-right: 6px;
  }
  .address-value {
    word-break: break-word;
    font-family: 'JetBrains Mono', monospace;
  }

  .confirm-send-btn {
    color: $bg-void;
    background: $primary;
    font-weight: 600;
  }
}

.header-popover {
    background: $bg-card;
    max-width: 250px !important;
    border: 1px solid $border-default;
}

// Modal styling
.modal.minimized {
    .q-input {
        .q-input-target {
            color: $text-primary;
        }
        &.q-if:hover:before {
            color: $text-primary;
        }
    }
}

.modal {
    color: $text-primary;

    .modal-header {
        margin-top: 6px;
        margin-left: 24px;
        text-align: left;
        font-size: 24px;
        font-weight: 600;
    }

    .q-header {
        .q-toolbar {
            &>* {
                color: $text-primary;
            }
        }
    }
}

.q-toolbar {
    background-color: $bg-panel;
}

.header {
    color: $text-primary;
}

.detail-page {
    color: $text-primary;
}

.q-radio {
    color: $text-primary;
    svg {
        color: $primary;
    }
}

// QR code modal
.qr-code-modal {
  padding: 25px;
  color: $text-primary;

  .qr-code-card {
    background-color: white;
    padding: 16px;
    border-radius: 8px;
  }
}

// Accent color classes
.oxen-light-teal {
    background: $secondary;
    color: $text-primary;
}

.oxen-navy {
    background: $bg-panel;
    color: $text-primary;
}

.oxen-teal {
    background: $primary;
    color: $bg-void;
}

// Startup icons
.startup-icons {
    .solid {
        color: $primary;
        g,path {
            fill: $primary;
        }
    }
}

// Separator
.hr-separator {
    height: 2px;
    background: $border-default;
    opacity: 0.5;
}

// Navigation styling
.navigation {
    .q-btn {
        background: $bg-card;
        color: $text-primary;
        border: 1px solid $border-subtle;
        border-radius: 8px;
        transition: all 0.2s ease;

        &:hover {
            background: $bg-hover;
            border-color: $border-default;
        }

        .q-icon {
            color: $primary;
        }
    }

    .router-link-exact-active > .q-btn {
        color: $bg-void;
        background: $primary;
        border-color: $primary;

        .q-icon {
            color: $bg-void;
        }
    }
}

// Wallet list
.wallet-list {
    .q-item-label {
        color: $text-primary;
    }

    .q-item {
        background: $bg-card;
        border: 1px solid $border-subtle;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
        transition: all 0.2s ease;

        .wallet-icon {
            color: $primary;
            g,path {
                fill: $primary;
            }
        }
    }

    .q-item:hover, .q-item.selected {
        background: $bg-hover !important;
        border-color: $primary;
        box-shadow: 0 4px 16px rgba(0, 212, 255, 0.2);

        .wallet-icon {
            color: $primary;
            g,path {
                fill: $primary;
            }
        }

        .q-icon {
            color: $primary;
        }
    }

    .q-item:active {
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.4);
    }
}

.wallet-settings {
  .q-btn {
    color: $text-primary;
  }
}

// Receive page
.receive {
    .list-header {
        color: $text-primary;
    }

    .q-separator-component {
        background-color: $border-subtle;
        opacity: 0.5;
    }

    .primary-address {
        background: linear-gradient(135deg, rgba(0, 212, 255, 0.15) 0%, rgba(0, 212, 255, 0.05) 100%) !important;
        border: 1px solid $primary !important;
        border-radius: 8px;

        .q-item, .q-item-side {
            color: $text-primary;

            .text-caption {
                color: $text-secondary;
                font-family: 'JetBrains Mono', monospace;
            }
        }

        .q-btn {
            color: $primary;
        }
    }

    .primary-address:hover {
        background: linear-gradient(135deg, rgba(0, 212, 255, 0.2) 0%, rgba(0, 212, 255, 0.1) 100%) !important;
    }
}

// Oxen list items
.oxen-list {
    .oxen-list-item {
        background: $bg-card;
        transition: all 0.2s ease;

        font-size: 16px;
        color: $text-primary;
        padding-top: 6px;
        padding-bottom: 6px;

        margin: 0 16px;
        border: 1px solid $border-subtle;
        border-radius: 8px;

        + .oxen-list-item {
            margin-top: 10px;
        }
    }

    .text-caption {
        color: $text-secondary;
    }

    .oxen-list-item:hover {
        background: $bg-hover;
        border-color: $border-default;
        cursor: pointer;
    }
}

.record-type-title {
  font-weight: 600;
  margin-bottom: 40px;
  padding-bottom: 40px;
  color: $text-primary;
}

.records-group {
  padding-bottom: 40px;
}

// Service node list
.service-node-list {
    .q-item {
        cursor: pointer;
        color: $text-primary;
        background: $bg-card;
        transition: all 0.2s ease;

        border: 1px solid $border-subtle;
        border-radius: 8px;

        + .q-item {
            margin-top: 10px;
        }

        .contrib-amounts {
            color: $text-secondary;
            font-family: 'JetBrains Mono', monospace;
        }
    }

    .q-item-label {
        color: $text-primary;
    }

    .fee {
        color: $text-secondary;
        font-family: 'JetBrains Mono', monospace;
    }

    .q-item:hover {
        background: $bg-hover;
        border-color: $border-default;
    }
}

.lokinet-expiration {
  width: 180px;
}

// ONS record list
.ons-record-list {
  .q-item {
    cursor: pointer;
    color: $text-primary;
    background: $bg-card;
    transition: all 0.2s ease;

    border: 1px solid $border-subtle;
    border-radius: 8px;

    .height {
      color: $text-secondary;
      font-family: 'JetBrains Mono', monospace;
    }

    div > span {
      color: $text-primary;
    }

    + .q-item {
      margin-top: 10px;
    }
  }

  .q-item:hover {
    background: $bg-hover;
    border-color: $border-default;
  }
}

.update-renew-buttons {
  .q-btn:not(:first-child) {
    margin-left: 8px;
  }
}

// Tab description
.tab-desc {
    color: $text-secondary;
    font-style: normal;
    b {
        color: $primary;
        font-style: italic;
    }
}

// Oxen field (form inputs)
.oxen-field {
    .content {
        border: 1px solid $border-default;
        background: $bg-input;
        border-radius: 8px;
        transition: all 0.2s ease;
    }

    &:not(.disable):not(.disable-hover) {
        .content:hover {
            background: $bg-card;
            border-color: $border-strong;
        }

        .content:focus-within {
            border-color: $primary;
            box-shadow: 0 0 0 2px rgba(0, 212, 255, 0.1);
        }
    }

    &.disable {
        .content {
            border-color: $border-subtle !important;
            opacity: 0.5;
        }
    }

    .content.error {
        border-color: $negative;
    }

    .label {
        color: $text-secondary;
        font-weight: 500;

        .optional {
            color: $text-muted;
        }
    }
}

// Welcome page
.welcome {
    .q-footer {
        background: $bg-panel;
    }
}

.welcome-container {
    color: $text-primary;
}

// Address book
.address-book, .address-header {
    .q-item-label, .header {
        color: $text-primary;
    }
}

// Prove transaction
.prove-transaction {
    .signature {
        background: $bg-card;
        border: 1px solid $border-default;
        border-radius: 8px;
        color: $text-primary;
        font-family: 'JetBrains Mono', monospace;
        padding: 12px;
    }
}

.signature-dialog {
    color: $text-primary;
}

// Check transaction
.check-transaction {
    .good {
        color: $positive;
    }

    .bad {
        color: $negative;
    }
}

.check-transaction, .prove-transaction {
    .title {
        color: $text-secondary;
        font-size: 14px;
        font-weight: 500;
    }
}

// Service node details
.serviceNodeDetails {
    .address {
        color: $text-primary;
        font-family: 'JetBrains Mono', monospace;
    }
    .name {
        color: $text-secondary;
    }
}

.non-selectable {
    color: $text-muted;
}

// Wallet creation page
.created {
    color: $text-primary;

  .wallet h6 {
    text-align: center;
  }

  .address {
    text-align: center;
    word-break: break-all;
    font-family: 'JetBrains Mono', monospace;
  }

  .seed-box {
    border: 1px solid $border-default;
    border-radius: 12px;
    margin: 16px;
    padding: 16px;
    background: $bg-card;

    div,
    h6 {
      text-align: center;
    }

    .seed {
      font-size: 20px;
      font-weight: 500;
      font-family: 'JetBrains Mono', monospace;
      line-height: 1.6;
    }

    .warning {
      color: $warning;
    }
  }

  h6 {
    font-size: 18px;
    margin: 8px 0;
    font-weight: 500;
  }

  .advanced-options-label {
    padding-left: 0;
    padding-right: 0;
  }
}

// Input text colors
.q-input input, .q-input textarea {
    color: $text-primary !important;

    &::placeholder {
        color: $text-muted !important;
    }
}

// Select dropdown
.q-select {
    color: $text-primary;

    .q-field__native {
        color: $text-primary;
    }
}

// Dialog styling
.q-dialog__inner > div {
    background: $bg-card;
    color: $text-primary;
    border: 1px solid $border-default;
    border-radius: 12px;
}

// Card styling
.q-card {
    background: $bg-card;
    color: $text-primary;
    border-radius: 12px;
}

// Button refinements
// Primary buttons: bright cyan background with white text
.q-btn.q-btn--standard {
    &.bg-primary {
        background: $primary !important;
        color: white !important;
        font-weight: 600;

        &:hover {
            background: lighten($primary, 10%) !important;
        }
    }
}

// Accent buttons: darker background with white text (like nav buttons)
.q-btn.bg-accent {
    background: $bg-card !important;
    color: white !important;
    border: 1px solid $border-subtle;
    font-weight: 500;

    &:hover {
        background: $bg-hover !important;
        border-color: $border-default;
    }
}

// Secondary buttons: similar darker style
.q-btn.bg-secondary {
    background: $bg-card !important;
    color: white !important;
    border: 1px solid $border-subtle;
    font-weight: 500;

    &:hover {
        background: $bg-hover !important;
        border-color: $border-default;
    }
}

// Notification styling
.q-notification {
    background: $bg-card;
    border: 1px solid $border-default;
    color: rgba(255, 255, 255, 0.9);

    &.bg-positive {
        background: rgba(0, 255, 136, 0.15);
        border-color: $positive;
        color: #ffffff;
    }

    &.bg-negative {
        background: rgba(255, 71, 87, 0.15);
        border-color: $negative;
        color: #ffffff;
    }

    &.bg-warning {
        background: rgba(255, 170, 0, 0.15);
        border-color: $warning;
        color: #ffffff;
    }
}

// Toolbar title background fix
.q-toolbar-title {
    background: $bg-void !important;
}

// Button toggle group styling (sub-navigation tabs)
.q-btn-toggle {
    background: $bg-card;
    border: 1px solid $border-default;
    border-radius: 4px;
    padding: 2px;

    .q-btn {
        border-radius: 3px !important;
        margin: 0;
        padding: 2px 10px;
        min-height: 22px;
        font-size: 11px;
        font-weight: 500;
        transition: all 0.2s ease;

        // Inactive state
        &:not(.bg-primary) {
            background: transparent !important;
            color: $text-secondary !important;

            &:hover {
                background: $bg-hover !important;
                color: $text-primary !important;
            }
        }

        // Active state (cyan highlight)
        &.bg-primary, &.text-primary {
            background: $primary !important;
            color: $bg-void !important;
            font-weight: 600;
        }

        // Remove default Quasar separator styling
        &:before {
            display: none !important;
        }
    }
}

// Table styling (q-table)
.q-table {
    background: transparent;
    color: $text-primary;

    // Header
    thead tr th {
        background: $bg-panel;
        color: $text-secondary;
        font-weight: 600;
        border-bottom: 1px solid $border-default;
    }

    // Body rows
    tbody tr {
        background: $bg-card;

        &:hover {
            background: $bg-hover;
        }

        td {
            color: $text-primary;
            border-bottom: 1px solid $border-subtle;
        }
    }

    // Pagination and bottom controls
    .q-table__bottom {
        background: $bg-panel;
        color: $text-secondary;
        border-top: 1px solid $border-subtle;

        .q-table__control {
            color: $text-secondary;
        }

        .q-table__separator {
            color: $text-muted;
        }
    }

    // Selection/input in pagination
    .q-field__native, .q-field__input {
        color: $text-primary !important;
    }

    // Sort icons
    .q-table__sort-icon {
        color: $text-muted;
    }

    // Loading overlay
    .q-table__middle {
        background: $bg-card;
    }
}

// Table card wrapper
.q-table__card {
    background: $bg-card;
    color: $text-primary;
    border: 1px solid $border-subtle;
    border-radius: 12px;
}
